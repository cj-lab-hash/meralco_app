<!DOCTYPE html>
<html>
<head>
  <title>Meralco Billing System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>

<body>
<div class="container mt-5">

  <h2>Electric Billing Entry</h2>
<button class="btn btn-secondary mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#newRecordForm">
    Add New Billing Record
  </button>

  <form method="POST" action="/" class="collapse" id="newRecordForm">
    <div class="mb-3">
      <label>Actual Bill (₱)</label>
      <input type="number" step="0.01" name="actual_bill" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Current Meter Consumption (kWh)</label>
      <input type="number" step="0.01" name="current_consumption" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Previous Meter Consumption (kWh)</label>
      <input type="number" step="0.01" name="previous_consumption" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Rate per kWh (₱)</label>
      <input type="number" step="0.01" name="rate_per_kwh" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Ate Gen Current Sub Meter Reading (kWh)</label>
      <input type="number" step="0.01" name="gen_current" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Ate Gen Previous Sub Meter Reading (kWh)</label>
      <input type="number" step="0.01" name="gen_previous" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Date of Meter Reading</label>
      <input type="date" name="billing_date" class="form-control" required>
    </div>

    <button type="submit" class="btn btn-primary">Submit</button>
  </form>

  <hr>

  <h3>Latest Billing Record</h3>
  <div class="table-responsive">
    <table class="table table-bordered">
      <thead bg="bg-dark">
        <tr class="text-warning">
          <th class="fs-3">Date of Meter Reading</th>
          <th class="fs-3">Actual Bill</th>
          <th class="fs-3">Total Consumption</th>
          <th class="fs-3">Rate/kWh</th>
          <th class="fs-3">Current Meter Reading</th>
          <th class="fs-3">Previous Meter Reading</th>
          <th class="fs-3">Ate Gen Previous Sub Meter Reading</th>
          <th class="fs-3">Ate Gen Current Sub Meter Reading</th>
          <th class="fs-3">Ate Gen Consumption</th>
          <th class="fs-3">Ate Gen Bill</th>
          <th class="fs-3">JM Bill</th>
        </tr>
      </thead>
      <tbody>
      <% if (record) { %>
        <tr>
          <td><%= record.date %></td>
          <td><%= record.formattedActualBill %></td>
          <td><%= record.total_consumption %></td>
          <td><%= record.formattedRate %></td>
          <td><%= record.current_reading %></td>
          <td><%= record.previous_reading %></td>
          <td><%= record.gen_previous %></td>
          <td><%= record.gen_current %></td>
          <td><%= record.gen_consumption %></td>
          <td><%= record.formattedGenBill %></td>
          <td><%= record.formattedJmBill %></td>
        </tr>
      <% } else { %>
        <tr><td colspan="11" class="text-center">No records yet.</td></tr>
      <% } %>
      </tbody>
    </table>
  </div>

  <button class="btn btn-secondary mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#allRecords">
    Show All Billing Records
  </button>

  <div class="collapse" id="allRecords">
    <div class="table-responsive">
      <table class="table table-bordered">
        <thead>
        <tr>
          <th>Date of Meter Reading</th>
          <th>Actual Bill</th>
          <th>Total Consumption</th>
          <th>Rate/kWh</th>
          <th>Current Meter Reading</th>
          <th>Previous Meter Reading</th>
          <th>Ate Gen Sub Meter Previous</th>
          <th>Ate Gen Sub Meter Current</th>
          <th>Ate Gen Current Consumption</th>
          <th>Ate Gen Bill</th>
          <th>JM Bill</th>
        </tr>
        </thead>

        <tbody>
        <% records.forEach(r => { %>
          <tr>
            <td><%= r.date %></td>
            <td><%= r.formattedActualBill %></td>
            <td><%= r.total_consumption %></td>
            <td><%= r.formattedRate %></td>
            <td><%= r.current_reading %></td>
            <td><%= r.previous_reading %></td>
            <td><%= r.gen_previous %></td>
            <td><%= r.gen_current %></td>
            <td><%= r.gen_consumption %></td>
            <td><%= r.formattedGenBill %></td>
            <td><%= r.formattedJmBill %></td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
