<!DOCTYPE html>
<html>
<head>
  <title>Meralco Billing System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>

<body>
<div class="container mt-5">

  <h2>Electric Billing Entry</h2>
<button class="btn btn-secondary mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#newRecordForm">
    Add New Billing Record
  </button>

  <form method="POST" action="/" class="collapse" id="newRecordForm">
    <div class="mb-3">
      <label>Actual Bill (₱)</label>
      <input type="number" step="0.01" name="actual_bill" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Current Meter Consumption (kWh)</label>
      <input type="number" step="0.01" name="current_consumption" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Previous Meter Consumption (kWh)</label>
    <!--  <input type="number" step="0.01" name="previous_consumption" class="form-control" required> -->
      <input type="number" step="0.01" name="previous_consumption" class="form-control" value="<%= lastCurrent %>" required>
    </div>

    <div class="mb-3">
      <label>Rate per kWh (₱)</label>
      <input type="number" step="0.01" name="rate_per_kwh" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Ate Gen Current Sub Meter Reading (kWh)</label>
      <input type="number" step="0.01" name="gen_current" class="form-control" required>
    </div>

    <div class="mb-3">
      <label>Ate Gen Previous Sub Meter Reading (kWh)</label>
    <!--  <input type="number" step="0.01" name="gen_previous" class="form-control" required> -->
    <input type="number" step="0.01" name="gen_previous" class="form-control" value="<%= lastGenCurrent %>" required>
    </div>

    <div class="mb-3">
      <label>Date of Meter Reading</label>
      <input type="date" name="billing_date" class="form-control" required>
    </div>

    <button type="submit" class="btn btn-primary">Submit</button>
  </form>

  <hr>

  <h3>Latest Billing Record</h3>
  <div class="table-responsive">
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>Date of Meter Reading</th>
          <th>Actual Bill</th>
          <th>Total Consumption</th>
          <th>Rate/kWh</th>
          <th>Current Meter Reading</th>
          <th>Previous Meter Reading</th>
          <th>Ate Gen Previous Sub Meter Reading</th>
          <th>Ate Gen Current Sub Meter Reading</th>
          <th>Ate Gen Consumption</th>
          <th>JM Consumption</th>
          <th>Ate Gen Bill</th>
          <th>JM Bill</th>
        </tr>
      </thead>
      <tbody>
      <% if (record) { %>
        <tr>
          <td><%= record.date %></td>
          <td><%= record.formattedActualBill %></td>
          <td><%= record.total_consumption %></td>
          <td><%= record.formattedRate %></td>
          <td><%= record.current_reading %></td>
          <td><%= record.previous_reading %></td>
          <td><%= record.gen_previous %></td>
          <td><%= record.gen_current %></td>
          <td><%= record.gen_consumption %></td>
          <td><%= record.total_consumption - record.gen_consumption %></td>
          <td><%= record.formattedGenBill %></td>
          <td><%= record.formattedJmBill %></td>
        </tr>
      <% } else { %>
        <tr><td colspan="11" class="text-center">No records yet.</td></tr>
      <% } %>
      </tbody>
    </table>
  </div>

  <button class="btn btn-secondary mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#allRecords">
    Show All Billing Records
  </button>

  <div class="collapse" id="allRecords">
    <div class="table-responsive">
      <table class="table table-bordered">
        <thead>
        <tr>
          <th>Date of Meter Reading</th>
          <th>Actual Bill</th>
          <th>Total Consumption</th>
          <th>Rate/kWh</th>
          <th>Current Meter Reading</th>
          <th>Previous Meter Reading</th>
          <th>Ate Gen Sub Meter Previous</th>
          <th>Ate Gen Sub Meter Current</th>
          <th>Ate Gen Current Consumption</th>
          <th>JM Consumption</th>
          <th>Ate Gen Bill</th>
          <th>JM Bill</th>
        </tr>
        </thead>

        
<tbody>
<% records.forEach(r => { %>
  <tr>
    <td><%= r.date %></td>
    <td><%= r.formattedActualBill %></td>
    <td><%= r.total_consumption %></td>
    <td><%= r.formattedRate %></td>
    <td><%= r.current_reading %></td>
    <td><%= r.previous_reading %></td>
    <td><%= r.gen_previous %></td>
    <td><%= r.gen_current %></td>
    <td><%= r.gen_consumption %></td>
    <td><%= r.jm_consumption %></td>  
    <td><%= r.formattedGenBill %></td>
    <td><%= r.formattedJmBill %></td>

    <!-- DELETE BUTTON -->
    <td>
      <form method="POST" action="/delete/<%= r.id %>" onsubmit="return confirmDelete()">
        <input type="password" name="password" class="form-control mb-1" placeholder="Enter password" required>
        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
      </form>
    </td>
  </tr>
<% }) %>
</tbody>

      </table>
    </div>
  </div>
    <button class="btn btn-primary mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#chartsSection">
  Show Consumption Graphs
    </button>

    <div class="collapse" id="chartsSection">
    <h3>Consumption Trends</h3>
    <canvas id="consumptionChart" height="80"></canvas>

    <h3 class="mt-4">Ate Gen vs JM Bill</h3>
    <canvas id="billChart" height="80"></canvas>
    </div>
</div>

<script>
function confirmDelete() {
  return confirm("Are you sure you want to delete this record?");
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<!--for the grapshs -->
<script>
async function loadCharts() {
  const res = await fetch("/api/records");
  const data = await res.json();

  const labels = data.map(r => r.date);
  const totalConsumption = data.map(r => r.total_consumption);
  const genConsumption = data.map(r => r.gen_consumption);
  const jmConsumption = data.map(r => r.total_consumption - r.gen_consumption);
  const jmBill = data.map(r => r.jm_bill);
  const genBill = data.map(r => r.gen_bill);
  

  // Chart 1: Consumption Trends
  new Chart(document.getElementById("consumptionChart"), {
    type: "line",
    data: {
      labels,
      datasets: [
        {
          label: "Total Consumption (kWh)",
          data: totalConsumption,
          borderColor: "blue",
          fill: false
        },
        {
          label: "Ate Gen Consumption (kWh)",
          data: genConsumption,
          borderColor: "orange",
          fill: false
        },
        {
          label: "JM Consumption (kWh)",
          data: jmConsumption,
          borderColor: "green",
          fill: false
        }
      ]
    }
  });

  // Chart 2: Billing Comparison
  new Chart(document.getElementById("billChart"), {
    type: "bar",
    data: {
      labels,
      datasets: [
        {
          label: "JM Bill (₱)",
          data: jmBill,
          backgroundColor: "green"
        },
        {
          label: "Ate Gen Bill (₱)",
          data: genBill,
          backgroundColor: "red"
        }
      
      ]
    }
  });
}

loadCharts();
</script>



</body>
</html>
